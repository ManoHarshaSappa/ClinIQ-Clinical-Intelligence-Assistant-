# Database (Supabase)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here

# MCP Configuration (Optional - for enhanced clinical intelligence)
FDA_API_KEY=your_fda_api_key_here
PUBMED_API_KEY=your_pubmed_api_key_here

# Clinical Features (Set to 'true' to enable MCP-enhanced features)
ENABLE_MCP_CLINICAL_INTELLIGENCE=true
ENABLE_ENHANCED_DRUG_CHECKING=true
ENABLE_EMERGENCY_PROTOCOLS=true

# Optional: Only needed if using external API
# NEXT_PUBLIC_API_URL=http://localhost:8000
